# =============================================================================
# AI Habit Coach — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.
# See /memory/ENV_VARS.md for full documentation.
# =============================================================================

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Web app (public — safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Mobile app (Expo — EXPO_PUBLIC_ prefix exposes to client bundle)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Anthropic Claude API ─────────────────────────────────────────────────────
# Server-side only — NEVER expose to browser or mobile client bundle
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── PostHog Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
EXPO_PUBLIC_POSTHOG_KEY=phc_your-posthog-project-api-key
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Sentry Error Tracking ────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=habit-coach-web
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mobile API base URL — used by Expo app to call Next.js API routes
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Supabase Edge Functions (server-only, used inside Deno functions) ────────
SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY is already defined above — reused in Edge Functions

# ─── Google OAuth (configured in Supabase Auth dashboard) ────────────────────
SUPABASE_AUTH_GOOGLE_CLIENT_ID=your-google-oauth-client-id
SUPABASE_AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# ─── Vercel (set automatically in Vercel deployments) ────────────────────────
# VERCEL_URL=auto-set-by-vercel
# VERCEL_ENV=production|preview|development
