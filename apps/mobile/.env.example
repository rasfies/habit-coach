# ─── HabitAI Mobile — Environment Variables ───────────────────────────────
# Copy this file to .env.local and fill in your values.
# All EXPO_PUBLIC_ variables are bundled into the app — do NOT put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (from Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to expose — RLS protects data)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Next.js API base URL (same deployment as web app)
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
EXPO_PUBLIC_API_URL=http://localhost:3000

# Sentry DSN for error tracking (optional)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# PostHog analytics key (optional)
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_posthog_key
