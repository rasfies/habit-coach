{
  "extends": "../../packages/config/typescript/base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@habit-coach/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@habit-coach/db": [
        "../../packages/db/src/index.ts"
      ]
    },
    "allowJs": true,
    "noEmit": true,
    "exactOptionalPropertyTypes": false
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
